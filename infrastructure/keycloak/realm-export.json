{
  "realm": "enagar",
  "enabled": true,
  "displayName": "eNagarSeba",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": false,
  "verifyEmail": false,
  "sslRequired": "external",
  "accessTokenLifespan": 900,
  "ssoSessionIdleTimeout": 28800,
  "ssoSessionMaxLifespan": 86400,
  "refreshTokenMaxReuse": 0,
  "revokeRefreshToken": true,
  "roles": {
    "realm": [
      {
        "name": "citizen",
        "description": "Citizen self-service user"
      },
      {
        "name": "tenant_clerk",
        "description": "Municipal clerk handling intake and processing"
      },
      {
        "name": "municipality_clerk",
        "description": "ULB clerk — grievance staff queues (alias of tenant_clerk for API parity; Hub H5.1)"
      },
      {
        "name": "municipality_admin",
        "description": "ULB admin — grievance escalation and staff queues (Hub H5.1)"
      },
      {
        "name": "tenant_admin",
        "description": "Municipal administrator for a tenant",
        "attributes": {
          "otp_required": ["true"]
        }
      },
      {
        "name": "state_admin",
        "description": "State-level administrator with cross-tenant duties",
        "attributes": {
          "otp_required": ["true"]
        }
      }
    ]
  },
  "clients": [
    {
      "clientId": "enagar-api",
      "name": "eNagarSeba API",
      "enabled": true,
      "bearerOnly": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false
    },
    {
      "clientId": "citizen-pwa",
      "name": "Citizen PWA",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": ["web-origins", "profile", "email", "roles", "tenant-claims"]
    },
    {
      "clientId": "citizen-rn",
      "name": "Citizen React Native",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["enagarseba://auth/*"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": ["profile", "email", "roles", "tenant-claims"]
    },
    {
      "clientId": "admin-tenant",
      "name": "Tenant Admin Portal",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:3002/*", "https://enagartenant.demosites.co.in/*"],
      "webOrigins": ["http://localhost:3002", "https://enagartenant.demosites.co.in"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3002/login##https://enagartenant.demosites.co.in/login"
      },
      "defaultClientScopes": ["web-origins", "profile", "email", "roles", "tenant-claims"]
    },
    {
      "clientId": "admin-state",
      "name": "State Admin Portal",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:3003/*", "https://enagarstate.demosites.co.in/*"],
      "webOrigins": ["http://localhost:3003", "https://enagarstate.demosites.co.in"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3003/login##https://enagarstate.demosites.co.in/login"
      },
      "defaultClientScopes": ["web-origins", "profile", "email", "roles", "tenant-claims"]
    },
    {
      "clientId": "staff-mobile",
      "name": "Staff Mobile",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["enagarstaff://auth/*"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": ["profile", "email", "roles", "tenant-claims"]
    }
  ],
  "clientScopes": [
    {
      "name": "tenant-claims",
      "description": "eNagarSeba tenant and ward claims required by the API RLS context",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "audience-enagar-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "enagar-api",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        },
        {
          "name": "tenant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "tenant_id",
            "claim.name": "tenant_id",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "tenant_code",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "tenant_code",
            "claim.name": "tenant_code",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "ward_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "ward_id",
            "claim.name": "ward_id",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "role",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "role",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "true",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "sub-username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "claim.name": "sub",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "true",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "amr",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-amr-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "acr",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-acr-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    }
  ]
}
