# Demo VM runtime — copy to `infrastructure/.env` on the VM (edit secrets).
# See docs/runbooks/unified-portal-env-matrix.md
#
# This file lists demo/staging values only. For local dev defaults see `.env.example`.

# ---- Postgres (edit password on VM) ----
POSTGRES_USER=enagar
POSTGRES_PASSWORD=CHANGE_ME_ON_VM
POSTGRES_DB=enagarseba
POSTGRES_PORT=5432
DATABASE_URL=postgresql://enagar:CHANGE_ME_ON_VM@localhost:5432/enagarseba?schema=public

# ---- CORS (all three portal origins) ----
CORS_ORIGIN=https://enagarcitizen.demosites.co.in,https://enagartenant.demosites.co.in,https://enagarstate.demosites.co.in

# ---- Redis ----
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_ON_VM
REDIS_URL=redis://:CHANGE_ME_ON_VM@127.0.0.1:6379

# ---- Document scan (demo VM: client simulation on) ----
ALLOW_CLIENT_SCAN_SIMULATION=true
DOCUMENT_SCAN_STUB=clean
DOCUMENT_UPLOAD_INTENT_LIMIT_PER_HOUR=30

# ---- MinIO (internal only — 127.0.0.1, not exposed via Caddy) ----
MINIO_ROOT_USER=enagar_admin
MINIO_ROOT_PASSWORD=CHANGE_ME_ON_VM
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_API_CORS_ALLOW_ORIGIN=https://enagarcitizen.demosites.co.in,https://enagartenant.demosites.co.in,https://enagarstate.demosites.co.in

OBJECT_STORAGE_DISABLED=false
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_PUBLIC_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_PUBLIC_BASE=http://127.0.0.1:9000
OBJECT_STORAGE_BUCKET=enagar-demo
OBJECT_STORAGE_ACCESS_KEY=enagar_admin
OBJECT_STORAGE_SECRET_KEY=CHANGE_ME_ON_VM
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_FORCE_PATH_STYLE=true

# Demo VM — external HTTPS browsers cannot PUT to presigned 127.0.0.1 URLs until a storage
# proxy exists. For public demo without MinIO browser PUT, use stub storage + scan simulation:
# OBJECT_STORAGE_DISABLED=true
# ALLOW_CLIENT_SCAN_SIMULATION=true  (already set above)

# ---- Keycloak (public issuer through Caddy) ----
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_ON_VM
KEYCLOAK_PORT=8080
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_REALM=enagar
KEYCLOAK_ISSUER_URL=https://enagarauth.demosites.co.in/realms/enagar
KEYCLOAK_TOKEN_ENDPOINT=https://enagarauth.demosites.co.in/realms/enagar/protocol/openid-connect/token
KEYCLOAK_LOGOUT_ENDPOINT=https://enagarauth.demosites.co.in/realms/enagar/protocol/openid-connect/logout
KEYCLOAK_CITIZEN_CLIENT_ID=citizen-pwa
KEYCLOAK_API_AUDIENCE=enagar-api

# Demo VM: disable dev OTP shortcuts
DEV_AUTH_ENABLED=false

# ---- Optional services (defaults OK if unused) ----
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
MEILI_PORT=7700
MEILI_MASTER_KEY=CHANGE_ME_ON_VM
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
