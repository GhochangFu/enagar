# =================================================================
# eNagarSeba — Local development environment
# Copy this file to `.env` (in this same folder) and edit values.
# `.env` is git-ignored. Never commit real secrets.
# =================================================================

# ---- Postgres ----
POSTGRES_USER=enagar
POSTGRES_PASSWORD=enagar_dev_pw_change_me
POSTGRES_DB=enagarseba
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev_pw_change_me

# ---- MinIO (S3-compatible object store) ----
MINIO_ROOT_USER=enagar_admin
MINIO_ROOT_PASSWORD=minio_dev_pw_change_me
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---- Keycloak (identity) ----
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=keycloak_dev_pw_change_me
KEYCLOAK_PORT=8080
KEYCLOAK_DB_NAME=keycloak

# ---- Qdrant (vector DB for RAG) ----
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# ---- Sahayak AI (chatbot) — provider adapter per ADR-0008 ----
# Active provider: openai | gemini | ollama
# Default in dev is `openai` if OPENAI_API_KEY is set, else `ollama` (offline profile).
LLM_PROVIDER=openai

# OpenAI (https://platform.openai.com)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional org / project pinning:
# OPENAI_ORG_ID=
# OPENAI_PROJECT_ID=

# Google Gemini (https://aistudio.google.com / Vertex AI)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Ollama (OPTIONAL — only used when LLM_PROVIDER=ollama or the `offline-llm`
# Compose profile is active). Bring it up with: `pnpm infra:up:offline`
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3.1:8b

# ---- Meilisearch (typo-tolerant search) ----
MEILI_PORT=7700
MEILI_MASTER_KEY=meili_dev_master_key_change_me

# ---- Mailhog (dev SMTP capture) ----
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
