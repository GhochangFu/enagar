# =================================================================
# eNagarSeba — Local development environment
# Copy this file to `.env` (in this same folder) and edit values.
# `.env` is git-ignored. Never commit real secrets.
# =================================================================

# ---- Postgres ----
POSTGRES_USER=enagar
POSTGRES_PASSWORD=enagar_dev_pw_change_me
POSTGRES_DB=enagarseba
POSTGRES_PORT=5432
DATABASE_URL=postgresql://enagar:enagar_dev_pw_change_me@localhost:5432/enagarseba?schema=public
# After first `pnpm --filter @enagar/api prisma:migrate:deploy`, run `pnpm db:seed` from repo root to insert `tenants` + `tenant_config`.
CORS_ORIGIN=http://localhost:3000,http://localhost:3002,http://localhost:3003,http://localhost:8081
# Demo VM — see infrastructure/.env.production.example and docs/runbooks/unified-portal-env-matrix.md:
# CORS_ORIGIN=https://enagarcitizen.demosites.co.in,https://enagartenant.demosites.co.in,https://enagarstate.demosites.co.in

# ---- Redis ----
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev_pw_change_me
REDIS_URL=redis://:redis_dev_pw_change_me@127.0.0.1:6379

# ---- Document virus scan (Sprint 6.27+) ----
# Local speed: client POST /scan-result after confirm (PWA mirrors this via load-infra-env.mjs when unset).
ALLOW_CLIENT_SCAN_SIMULATION=true
# Worker stub when queue mode: clean | infected | failed (EICAR bytes always infected).
DOCUMENT_SCAN_STUB=clean
DOCUMENT_UPLOAD_INTENT_LIMIT_PER_HOUR=30

# ---- MinIO (S3-compatible object store) ----
MINIO_ROOT_USER=enagar_admin
MINIO_ROOT_PASSWORD=minio_dev_pw_change_me
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# Browser PUT CORS for MinIO (global — recreate minio container after edits). See configure-minio-cors.mjs.
MINIO_API_CORS_ALLOW_ORIGIN=http://localhost:3000,http://localhost:3002,http://localhost:3003,http://localhost:8081

# ---- Object storage (API — Sprint 6.25+) ----
# Omit or set OBJECT_STORAGE_DISABLED=true to keep minio:// stub URLs (CI default).
# With MinIO running (pnpm infra:up), set DISABLED=false for real presigned PUT/GET:
OBJECT_STORAGE_DISABLED=true
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_PUBLIC_ENDPOINT=http://127.0.0.1:9000
# Optional CDN/browser base for branding public_url (defaults to public endpoint).
OBJECT_STORAGE_PUBLIC_BASE=http://127.0.0.1:9000
OBJECT_STORAGE_BUCKET=enagar-local
OBJECT_STORAGE_ACCESS_KEY=enagar_admin
OBJECT_STORAGE_SECRET_KEY=minio_dev_pw_change_me
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_FORCE_PATH_STYLE=true

# ---- Keycloak (identity) ----
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=keycloak_dev_pw_change_me
KEYCLOAK_PORT=8080
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_REALM=enagar
KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/enagar
KEYCLOAK_TOKEN_ENDPOINT=http://localhost:8080/realms/enagar/protocol/openid-connect/token
KEYCLOAK_LOGOUT_ENDPOINT=http://localhost:8080/realms/enagar/protocol/openid-connect/logout
# Demo VM — unified portal Option A (docs/runbooks/unified-portal-keycloak-phase4.md):
# KEYCLOAK_ISSUER_URL=https://enagarauth.demosites.co.in/realms/enagar
# KEYCLOAK_TOKEN_ENDPOINT=https://enagarauth.demosites.co.in/realms/enagar/protocol/openid-connect/token
# KEYCLOAK_LOGOUT_ENDPOINT=https://enagarauth.demosites.co.in/realms/enagar/protocol/openid-connect/logout
KEYCLOAK_OTP_ENDPOINT=
KEYCLOAK_CITIZEN_CLIENT_ID=citizen-pwa
KEYCLOAK_API_AUDIENCE=enagar-api
# Accept multiple JWT `aud` values (comma-separated). Example if tokens still list only `account`:
# KEYCLOAK_API_AUDIENCE=enagar-api,account
# Optional: shared password for scripted dummy users (pnpm infra:seed-keycloak-users)
# KEYCLOAK_DUMMY_USER_PASSWORD=DummyDev_2026!ChangeMe
DEV_AUTH_ENABLED=true
DEV_OTP_CODE=12345
DEV_JWT_SECRET=enagarseba_dev_only_secret_change_me

# ---- Qdrant (vector DB for RAG) ----
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# ---- Sahayak AI (chatbot) — provider adapter per ADR-0008 ----
# Active provider: openai | gemini | ollama
# Default in dev is `openai` if OPENAI_API_KEY is set, else `ollama` (offline profile).
LLM_PROVIDER=openai

# OpenAI (https://platform.openai.com)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional org / project pinning:
# OPENAI_ORG_ID=
# OPENAI_PROJECT_ID=

# Google Gemini (https://aistudio.google.com / Vertex AI)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Ollama (OPTIONAL — only used when LLM_PROVIDER=ollama or the `offline-llm`
# Compose profile is active). Bring it up with: `pnpm infra:up:offline`
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3.1:8b

# ---- Meilisearch (typo-tolerant search) ----
MEILI_PORT=7700
MEILI_MASTER_KEY=meili_dev_master_key_change_me

# ---- Mailhog (dev SMTP capture) ----
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
