{
  "name": "enagarseba",
  "version": "0.0.0",
  "private": true,
  "description": "eNagarSeba — Multi-tenant municipal services platform for West Bengal. Monorepo root.",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --concurrency=20",
    "dev:portals": "turbo run dev --filter=@enagar/api --filter=@enagar/citizen-pwa --filter=@enagar/admin-tenant --filter=@enagar/admin-state",
    "dev:hub": "npx --yes serve infrastructure/portal-hub -p 5500",
    "lint": "turbo run lint -- --max-warnings=0",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "test:security": "jest --config tests/security/jest.config.cjs",
    "build:portal-demo": "node scripts/build-unified-portal-demo.mjs",
    "verify:portal-demo": "node scripts/verify-unified-portal-demo-build.mjs",
    "security:zap:auth": "node scripts/run-zap-auth-scan.mjs",
    "db:seed": "pnpm --filter @enagar/api exec prisma db seed",
    "seed:tenant": "node scripts/seed-tenant.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean && rimraf node_modules .turbo",
    "infra:up": "docker compose -f infrastructure/docker-compose.yml --env-file infrastructure/.env up -d",
    "infra:up:demo": "docker compose -f infrastructure/docker-compose.yml -f infrastructure/docker-compose.override.yml --env-file infrastructure/.env up -d",
    "infra:demo:keycloak": "docker compose -f infrastructure/docker-compose.yml -f infrastructure/docker-compose.override.yml --env-file infrastructure/.env up -d --force-recreate keycloak",
    "infra:up:offline": "docker compose -f infrastructure/docker-compose.yml --env-file infrastructure/.env --profile offline-llm up -d",
    "infra:down": "docker compose -f infrastructure/docker-compose.yml --env-file infrastructure/.env --profile offline-llm down",
    "infra:logs": "docker compose -f infrastructure/docker-compose.yml --env-file infrastructure/.env logs -f",
    "infra:reset": "docker compose -f infrastructure/docker-compose.yml --env-file infrastructure/.env --profile offline-llm down -v",
    "infra:seed-keycloak-users": "node infrastructure/scripts/seed-keycloak-dummy-users.mjs",
    "infra:minio-cors": "pnpm --filter @enagar/api exec node ../../infrastructure/scripts/configure-minio-cors.mjs",
    "infra:pull-llm": "docker exec enagar-ollama ollama pull llama3.1:8b",
    "rag:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File services/rag-indexer/run-indexer.ps1",
    "rag:dev:reload": "powershell -NoProfile -ExecutionPolicy Bypass -File services/rag-indexer/run-indexer.ps1 -Reload",
    "smoke:phase7-vm": "node scripts/smoke-phase-7-vm-pilot.mjs",
    "smoke:phase8-desk": "node scripts/smoke/phase8-desk-reject-return-smoke.mjs",
    "smoke:phase9": "node scripts/smoke/phase9-municipal-signoff-smoke.mjs",
    "smoke:phase9-ui": "node scripts/smoke/phase9-municipal-desk-ui-smoke.mjs",
    "smoke:phase10": "node scripts/smoke/phase10-hoarding-e2e-smoke.mjs",
    "smoke:phase11": "node scripts/smoke/phase11-post-approval-payment-smoke.mjs",
    "smoke:phase11-ui": "node scripts/smoke/phase11-post-approval-desk-ui-smoke.mjs",
    "smoke:phase13-upfront": "node scripts/smoke/phase13-upfront-payment-smoke.mjs",
    "smoke:phase13-dual": "node scripts/smoke/phase13-dual-payment-smoke.mjs",
    "smoke:phase13-deferred": "node scripts/smoke/phase13-deferred-payment-smoke.mjs",
    "smoke:phase13-free": "node scripts/smoke/phase13-free-payment-smoke.mjs",
    "smoke:phase13-matrix": "node scripts/smoke/phase13-regression-matrix.mjs",
    "smoke:phase12-pwd": "node scripts/smoke/phase12-pwd-e2e-smoke.mjs",
    "smoke:phase14-org": "node scripts/smoke/phase14-org-onboarding-smoke.mjs",
    "smoke:hoarding-boc": "node scripts/smoke/hoarding-boc-e2e-smoke.mjs",
    "verify:en3": "node scripts/verify-en3-state-onboarding.mjs",
    "verify:en4": "node scripts/verify-en4-global-onboarding-forms.mjs",
    "verify:en5": "node scripts/verify-en5-shared-form-builder.mjs",
    "prepare": "husky"
  },
  "pnpm": {
    "overrides": {
      "eslint>ajv": "6.12.6",
      "@eslint/eslintrc>ajv": "6.12.6",
      "@typescript-eslint/eslint-plugin": "8.43.0",
      "@typescript-eslint/parser": "8.43.0",
      "@xmldom/xmldom": "0.9.10",
      "glob": "10.5.0",
      "lodash": "4.18.0",
      "multer": "2.1.1",
      "tar": "7.5.11"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@types/jest": "^29.5.13",
    "@types/node": "^26.0.0",
    "husky": "^9.1.6",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.5",
    "turbo": "^2.1.3",
    "typescript": "^5.5.4"
  }
}
