{
  "name": "@enagar/forms",
  "version": "0.0.0",
  "private": true,
  "description": "JSON-Schema-driven form runtime — single source of truth for citizen forms across web + mobile.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./fixtures": "./src/fixtures.ts",
    "./upload": "./src/application-document-upload.ts",
    "./web": "./src/web/DynamicFormFields.tsx",
    "./builder": "./src/builder/index.ts",
    "./form-import": "./dist/form-import/index.js",
    "./form-import-ui": "./src/form-import-ui/index.ts"
  },
  "typesVersions": {
    "*": {
      "web": [
        "src/web/DynamicFormFields.tsx"
      ],
      "fixtures": [
        "src/fixtures.ts"
      ],
      "upload": [
        "src/application-document-upload.ts"
      ],
      "builder": [
        "src/builder/index.ts"
      ],
      "form-import": [
        "dist/form-import/index.d.ts"
      ],
      "form-import-ui": [
        "src/form-import-ui/index.ts"
      ],
      "*": [
        "src/index.ts"
      ]
    }
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run build && node --test test/run-tests.mjs",
    "build": "tsc",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@enagar/types": "workspace:*",
    "@enagar/ui": "workspace:*"
  },
  "devDependencies": {
    "@enagar/config": "workspace:*",
    "@types/react": "^18.3.11",
    "eslint": "^8.57.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.5.4"
  }
}
