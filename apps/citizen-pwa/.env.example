# Local overrides — copy to `.env.local` for Next.js dev.
# By default `next.config.mjs` loads `../../infrastructure/.env` in dev only
# and mirrors ALLOW_CLIENT_SCAN_SIMULATION → NEXT_PUBLIC_ALLOW_CLIENT_SCAN_SIMULATION.

NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
NEXT_PUBLIC_ALLOW_CLIENT_SCAN_SIMULATION=true

# Demo VM production build — use `.env.production.example` → `.env.production.local`
# See docs/runbooks/unified-portal-env-matrix.md
