  "dependencies": {
    "@enagar/forms": "workspace:^",
    "@enagar/tenant-theme": "workspace:^",
    "@enagar/types": "workspace:*",
    "@enagar/ui": "workspace:^",
    "@enagar/workflow": "workspace:^",
    "@xyflow/react": "^12.10.2",
    "leaflet": "^1.9.4",
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@enagar/config": "workspace:*",
    "@types/jest": "^29.5.13",
    "@types/leaflet": "^1.9.12",
    "@types/node": "^20.16.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.5.0",
    "eslint-config-next": "14.2.35",
    "jest": "^29.7.0",
    "postcss": "^8.4.47",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.13",
    "ts-jest": "^29.2.5",
    "typescript": "^5.5.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
