{
  "name": "@enagar/admin-tenant",
  "version": "0.0.0",
  "private": true,
  "description": "Per-municipality admin portal (Phase 6 — Tenant Admin).",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "dev": "next dev -p 3002",
