# Local overrides — copy to `.env.local` for Next.js.

NEXT_PUBLIC_KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/enagar
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=admin-tenant
NEXT_PUBLIC_ADMIN_APP_ORIGIN=http://localhost:3002
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
# Optional — unified portal hub (defaults: localhost:5500 locally, https://enagar.demosites.co.in on demo)
# NEXT_PUBLIC_PORTAL_HUB_URL=http://localhost:5500

# Demo VM production build — copy `.env.production.example` → `.env.production.local`
# See docs/runbooks/unified-portal-env-matrix.md
# NEXT_PUBLIC_KEYCLOAK_ISSUER_URL=https://enagarauth.demosites.co.in/realms/enagar
# NEXT_PUBLIC_ADMIN_APP_ORIGIN=https://enagartenant.demosites.co.in
# NEXT_PUBLIC_API_BASE_URL=https://enagarapi.demosites.co.in/api
# KEYCLOAK_INTERNAL_ISSUER_URL=http://localhost:8080/realms/enagar
