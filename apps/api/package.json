{
  "name": "@enagar/api",
  "version": "0.0.0",
  "private": true,
  "description": "eNagarSeba backend API (NestJS, Node 20, TypeScript). Per ADR-0002.",
  "license": "AGPL-3.0-or-later",
  "type": "commonjs",
  "scripts": {
    "dev": "pnpm --filter @enagar/forms build && nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "eslint src",
    "prisma:generate": "prisma generate",
    "postinstall": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "prisma:validate": "prisma validate",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:e2e": "jest --config test/jest-e2e.json --passWithNoTests",
    "fixtures:form-import": "node scripts/generate-form-import-fixtures.mjs",
    "clean": "rimraf dist .turbo .tsbuildinfo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1051.0",
    "@aws-sdk/s3-request-presigner": "^3.1051.0",
    "@enagar/forms": "workspace:^",
    "@enagar/smart-city-adapters": "workspace:*",
    "@enagar/types": "workspace:*",
    "@enagar/workflow": "workspace:^",
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/terminus": "^10.2.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "7.8.0",
    "bullmq": "^5.34.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "fast-xml-parser": "^5.9.3",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jose": "^6.2.3",
    "jszip": "^3.10.1",
    "nestjs-pino": "^4.1.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.19.0",
    "pg": "^8.20.0",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.2.2",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@enagar/config": "workspace:*",
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.4",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.13",
    "@types/node": "^26.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "docx": "^9.7.1",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "pdf-to-png-converter": "^4.1.1",
    "prisma": "^7.8.0",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0",
    "tesseract.js": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "testEnvironment": "node"
  }
}
