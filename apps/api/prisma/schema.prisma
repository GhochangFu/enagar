generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RentalAssetType {
  HOARDING
  MARKET_STALL
  LAND
  COMMUNITY_HALL_LONG_TERM
  OTHER
}

enum RentalAssetStatus {
  AVAILABLE
  RENTED
  MAINTENANCE
  RESERVED
}

enum LeaseAgreementStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

enum LeaseAgreementDocumentStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum LeaseAgreementDocumentEventType {
  UPLOADED
  APPROVED
  REJECTED
}

enum LeaseInvoiceStatus {
  PENDING
  PAID
  OVERDUE
  WAIVED
}

enum RatePeriod {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum ParkingBayStatus {
  FREE
  OCCUPIED
  RESERVED
  OUT_OF_SERVICE
}

model Tenant {
  id                       String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                     String                   @unique @db.VarChar(20)
  name                     String                   @db.VarChar(255)
  district                 String?                  @db.VarChar(100)
  wardCount                Int?                     @map("ward_count")
  lateFeePaise             Int?                     @map("late_fee_paise")
  themeColor               String?                  @map("theme_color") @db.VarChar(7)
  logoUrl                  String?                  @map("logo_url")
  languagesEnabled         String[]                 @default(["en", "bn", "hi"]) @map("languages_enabled")
  config                   Json                     @default(dbgenerated("'{}'::jsonb"))
  isActive                 Boolean                  @default(true) @map("is_active")
  createdAt                DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenantConfig             TenantConfig?
  banners                  TenantBanner[]
  boroughs                 Borough[]
  citizens                 Citizen[]
  localities               Locality[]
  tariffs                  TenantTariff[]
  notifications            Notification[]
  notificationTemplates    NotificationTemplate[]
  pushDevices              CitizenPushDevice[]
  kbArticles               KbArticle[]
  kbIndexJobs              KbIndexJob[]
  brandingAssets           TenantBrandingAsset[]
  bookableAssets           BookableAsset[]
  bookingReservations      BookingReservation[]
  stateAuditLogs           StateAuditLog[]
  chatbotAuditLogs         ChatbotAuditLog[]
  chatbotSessions          ChatbotSession[]
  chatbotConsents          ChatbotConsent[]
  chatbotFeedback          ChatbotFeedback[]
  impersonationTokens      ImpersonationToken[]
  staffInvites             StaffInvite[]
  applicationComments      ApplicationComment[]
  applicationDocuments     ApplicationDocument[]
  applicationTimeline      ApplicationTimeline[]
  applications             Application[]
  paymentIdempotencyKeys   PaymentIdempotencyKey[]
  payments                 Payment[]
  receipts                 Receipt[]
  glPostings               GlPosting[]
  deposits                 Deposit[]
  refundDispatches         RefundDispatch[]
  challans                 Challan[]
  grievances               Grievance[]
  grievanceRoutingRules    GrievanceRoutingRule[]
  grievanceSlaPolicies     SlaPolicy[]
  grievanceTimelineEntries GrievanceTimelineEntry[]
  grievanceAttachments     GrievanceAttachment[]
  grievanceCategories      TenantGrievanceCategory[]
  grievanceSubtypes        TenantGrievanceSubtype[]
  departments              TenantDepartment[]
  designations             TenantDesignation[]
  userDesignations         UserDesignation[]
  serviceCategories        TenantServiceCategory[]
  holdingLookupAudit       HoldingLookupAudit[]
  holdingRecords           HoldingRecord[]
  roleStageMaps            RoleStageMap[]
  designationStageMaps     DesignationStageMap[]
  serviceFormVersions      ServiceFormVersion[]
  services                 TenantService[]
  userRoles                UserRole[]
  users                    User[]
  wards                    Ward[]
  workflowStages           WorkflowStage[]
  workflowTransitions      WorkflowTransition[]
  workflows                Workflow[]
  tenantVendors            TenantVendor[]
  workOrders               WorkOrder[]
  rentalAssets             RentalAsset[]
  leaseAgreements          LeaseAgreement[]
  leaseInvoices            LeaseInvoice[]
  leaseAgreementDocuments LeaseAgreementDocument[]
  leaseAgreementDocumentEvents LeaseAgreementDocumentEvent[]
  smartZones               SmartZone[]
  parkingBays              ParkingBay[]
  evChargers               EvCharger[]
  evSessions               EvSession[]
  waterMeterAccounts       WaterMeterAccount[]
  waterMeterRecharges      WaterMeterRecharge[]

  @@map("tenants")
}

model TenantConfig {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @unique @map("tenant_id") @db.Uuid
  defaultLanguage String   @default("en") @map("default_language") @db.VarChar(5)
  timezone        String   @default("Asia/Kolkata") @db.VarChar(64)
  contactPhone    String?  @map("contact_phone") @db.VarChar(20)
  contactEmail    String?  @map("contact_email") @db.VarChar(255)
  branding        Json     @default(dbgenerated("'{}'::jsonb"))
  featureFlags    Json     @default(dbgenerated("'{}'::jsonb")) @map("feature_flags")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_config")
}

model TenantBanner {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  code      String    @db.VarChar(80)
  severity  String    @default("info") @db.VarChar(20)
  title     Json
  body      Json
  linkUrl   String?   @map("link_url")
  startsAt  DateTime? @map("starts_at") @db.Timestamptz(6)
  endsAt    DateTime? @map("ends_at") @db.Timestamptz(6)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, isActive, startsAt, endsAt])
  @@map("tenant_banners")
}

model Citizen {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String              @map("tenant_id") @db.Uuid
  keycloakSubject    String?             @map("keycloak_subject") @db.VarChar(255)
  mobile             String              @db.VarChar(15)
  aadhaarHash        String?             @map("aadhaar_hash") @db.Char(64)
  name               String?             @db.VarChar(255)
  address            Json?               @default(dbgenerated("'{}'::jsonb"))
  wardId             String?             @map("ward_id") @db.Uuid
  holdingNumber      String?             @map("holding_number") @db.VarChar(50)
  languagePref       String              @default("en") @map("language_pref") @db.VarChar(5)
  selectedTenantCode String?             @map("selected_tenant_code") @db.VarChar(20)
  pinnedTenantCodes  Json                @default(dbgenerated("'[]'::jsonb")) @map("pinned_tenant_codes")
  pinnedServices     Json                @default(dbgenerated("'[]'::jsonb")) @map("pinned_services")
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ward               Ward?               @relation(fields: [wardId], references: [id], onDelete: SetNull)
  notifications      Notification[]
  pushDevices        CitizenPushDevice[]
  applications       Application[]
  chatbotSessions    ChatbotSession[]
  chatbotConsents    ChatbotConsent[]
  chatbotFeedback    ChatbotFeedback[]
  deposits           Deposit[]
  bookingReservations BookingReservation[]
  challans           Challan[]
  grievances         Grievance[]
  leaseAgreements    LeaseAgreement[]
  evSessions         EvSession[]
  waterMeterAccounts WaterMeterAccount[]

  @@unique([tenantId, mobile])
  @@unique([tenantId, keycloakSubject])
  @@index([tenantId, keycloakSubject])
  @@index([tenantId, wardId])
  @@map("citizens")
}

model User {
  id                      String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                String                 @map("tenant_id") @db.Uuid
  keycloakUserId          String                 @unique @map("keycloak_user_id") @db.Uuid
  username                String                 @db.VarChar(100)
  email                   String?                @db.VarChar(255)
  mobile                  String?                @db.VarChar(15)
  displayName             String                 @map("display_name") @db.VarChar(255)
  status                  String                 @default("active") @db.VarChar(20)
  createdAt               DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant                  Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles               UserRole[]
  challansIssued          Challan[]
  grievancesAssigned      Grievance[]            @relation("GrievanceAssignee")
  grievanceRoutingAssigns GrievanceRoutingRule[] @relation("RoutingAssignUser")
  userDesignations        UserDesignation[]
  assignedWorkOrders      WorkOrder[]            @relation("WorkOrderAssignee")

  @@unique([tenantId, username])
  @@index([tenantId, status])
  @@map("users")
}

model Role {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String     @unique @db.VarChar(50)
  name        String     @db.VarChar(100)
  description String?
  isSystem    Boolean    @default(true) @map("is_system")
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  userRoles   UserRole[]

  @@map("roles")
}

model UserRole {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  wardId    String?  @map("ward_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ward      Ward?    @relation(fields: [wardId], references: [id], onDelete: SetNull)

  @@unique([tenantId, userId, roleId, wardId])
  @@index([tenantId, roleId])
  @@map("user_roles")
}

model StaffInvite {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  username         String   @db.VarChar(100)
  displayName      String   @map("display_name") @db.VarChar(255)
  email            String?  @db.VarChar(255)
  mobile           String?  @db.VarChar(15)
  roleCodes        String[] @default([]) @map("role_codes")
  wardNumber       String?  @map("ward_number") @db.VarChar(20)
  status           String   @default("draft") @db.VarChar(30)
  provisioningMode String   @default("dry_run") @map("provisioning_mode") @db.VarChar(30)
  keycloakUserId   String?  @map("keycloak_user_id") @db.Uuid
  invitedBySubject String   @map("invited_by_subject") @db.VarChar(255)
  failureReason    String?  @map("failure_reason")
  metadata         Json     @default(dbgenerated("'{}'::jsonb"))
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, username])
  @@index([tenantId, status])
  @@map("staff_invites")
}

model Borough {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  code      String   @db.VarChar(20)
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  wards     Ward[]

  @@unique([tenantId, code])
  @@map("boroughs")
}

model Ward {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String                 @map("tenant_id") @db.Uuid
  boroughId             String?                @map("borough_id") @db.Uuid
  number                String                 @db.VarChar(20)
  name                  String?                @db.VarChar(100)
  councillor            String?                @db.VarChar(255)
  boundary              Json?                  @default(dbgenerated("'{}'::jsonb"))
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  borough               Borough?               @relation(fields: [boroughId], references: [id], onDelete: SetNull)
  citizens              Citizen[]
  localities            Locality[]
  grievanceRoutingRules GrievanceRoutingRule[]
  smartZones            SmartZone[]
  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles             UserRole[]

  @@unique([tenantId, number])
  @@index([tenantId, boroughId])
  @@map("wards")
}

model Locality {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  wardId    String?  @map("ward_id") @db.Uuid
  mouza     String?  @db.VarChar(120)
  name      String   @db.VarChar(150)
  pincode   String?  @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ward      Ward?    @relation(fields: [wardId], references: [id], onDelete: SetNull)

  @@unique([tenantId, name, pincode])
  @@index([tenantId, wardId])
  @@index([tenantId, mouza])
  @@map("localities")
}

model TenantTariff {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  code       String   @db.VarChar(80)
  category   String   @db.VarChar(40)
  name       Json
  rateConfig Json     @default(dbgenerated("'{}'::jsonb")) @map("rate_config")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, category, isActive])
  @@map("tenant_tariffs")
}

model Notification {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  citizenId String?   @map("citizen_id") @db.Uuid
  type      String    @db.VarChar(30)
  title     String    @db.VarChar(255)
  body      String
  deepLink  String?   @map("deep_link")
  isRead    Boolean   @default(false) @map("is_read")
  sentAt    DateTime  @default(now()) @map("sent_at") @db.Timestamptz(6)
  readAt    DateTime? @map("read_at") @db.Timestamptz(6)
  citizen   Citizen?  @relation(fields: [citizenId], references: [id], onDelete: SetNull)
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, citizenId, isRead])
  @@map("notifications")
}

model NotificationTemplate {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  code      String   @db.VarChar(80)
  channel   String   @db.VarChar(20)
  locale    String   @db.VarChar(5)
  trigger   String   @db.VarChar(80)
  subject   String?  @db.VarChar(255)
  body      String
  variables Json     @default(dbgenerated("'[]'::jsonb"))
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code, channel, locale])
  @@index([tenantId, channel, locale, isActive])
  @@index([tenantId, trigger])
  @@map("notification_templates")
}

model CitizenPushDevice {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  citizenId String   @map("citizen_id") @db.Uuid
  platform  String   @db.VarChar(12)
  token     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  citizen   Citizen  @relation(fields: [citizenId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([citizenId, token])
  @@index([tenantId, citizenId])
  @@map("citizen_push_devices")
}

model KbArticle {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String       @map("tenant_id") @db.Uuid
  slug        String       @db.VarChar(120)
  title       Json
  body        Json
  tags        String[]     @default([])
  status      String       @default("draft") @db.VarChar(20)
  publishedAt DateTime?    @map("published_at") @db.Timestamptz(6)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  indexJobs   KbIndexJob[]
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@index([tags], type: Gin)
  @@map("kb_articles")
}

model KbIndexJob {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  articleId   String    @map("article_id") @db.Uuid
  status      String    @default("queued") @db.VarChar(20)
  trigger     String    @default("publish") @db.VarChar(30)
  requestedBy String?   @map("requested_by") @db.VarChar(255)
  error       String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)
  article     KbArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, createdAt])
  @@map("kb_index_jobs")
}

model TenantBrandingAsset {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  code       String   @db.VarChar(80)
  kind       String   @db.VarChar(20)
  storageKey String   @map("storage_key") @db.VarChar(255)
  publicUrl  String   @map("public_url")
  mimeType   String   @map("mime_type") @db.VarChar(80)
  sizeBytes  Int      @map("size_bytes")
  width      Int?
  height     Int?
  metadata   Json     @default(dbgenerated("'{}'::jsonb"))
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, kind, createdAt])
  @@map("tenant_branding_assets")
}

model StateAuditLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorSubject   String   @map("actor_subject") @db.VarChar(255)
  actorRole      String   @map("actor_role") @db.VarChar(80)
  action         String   @db.VarChar(80)
  targetTenantId String?  @map("target_tenant_id") @db.Uuid
  targetCode     String?  @map("target_code") @db.VarChar(80)
  metadata       Json     @default(dbgenerated("'{}'::jsonb"))
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  targetTenant   Tenant?  @relation(fields: [targetTenantId], references: [id], onDelete: SetNull)

  @@index([actorSubject, createdAt])
  @@index([targetTenantId, createdAt])
  @@index([action, createdAt])
  @@map("state_audit_logs")
}

model ChatbotAuditLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestId      String   @default(dbgenerated("gen_random_uuid()")) @map("request_id") @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  citizenId      String?  @map("citizen_id") @db.Uuid
  sessionId      String   @map("session_id") @db.VarChar(64)
  provider       String   @db.VarChar(20)
  model          String   @db.VarChar(80)
  inputTokens    Int?     @map("input_tokens")
  outputTokens   Int?     @map("output_tokens")
  latencyMs      Int      @map("latency_ms")
  redactionCount Int      @default(0) @map("redaction_count")
  queryHash      String   @map("query_hash") @db.VarChar(64)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, sessionId, createdAt(sort: Desc)])
  @@map("chatbot_audit_logs")
}

model ChatbotSession {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String           @map("tenant_id") @db.Uuid
  citizenId  String?          @map("citizen_id") @db.Uuid
  sessionKey String           @map("session_key") @db.VarChar(64)
  language   String           @default("en") @db.VarChar(5)
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  citizen    Citizen?         @relation(fields: [citizenId], references: [id], onDelete: SetNull)
  messages   ChatbotMessage[]

  @@unique([tenantId, sessionKey])
  @@index([tenantId, citizenId, updatedAt(sort: Desc)])
  @@map("chatbot_sessions")
}

model ChatbotMessage {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId String         @map("session_id") @db.Uuid
  role      String         @db.VarChar(20)
  content   String
  citations Json           @default(dbgenerated("'[]'::jsonb"))
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  session   ChatbotSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  feedback             ChatbotFeedback[]

  @@index([sessionId, createdAt])
  @@map("chatbot_messages")
}

model ChatbotConsent {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  citizenId          String   @map("citizen_id") @db.Uuid
  mode               String   @db.VarChar(20)
  disclosureVersion  String   @default("2026-05") @map("disclosure_version") @db.VarChar(20)
