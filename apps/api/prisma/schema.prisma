model Grievance {
  id                String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String                   @map("tenant_id") @db.Uuid
  citizenId         String                   @map("citizen_id") @db.Uuid
  grievanceNo       String                   @map("grievance_no") @db.VarChar(64)
  category          String                   @db.VarChar(50)
  subtypeCode       String?                  @map("subtype_code") @db.VarChar(50)
  description       String
  location          Json                     @default(dbgenerated("'{}'::jsonb"))
  photoKeys         Json                     @default(dbgenerated("'[]'::jsonb")) @map("photo_keys")
  grievancePriority String                   @default("medium") @map("grievance_priority") @db.VarChar(20)
  status            String                   @default("submitted") @db.VarChar(30)
  routedRoleCode    String?                  @map("routed_role_code") @db.VarChar(50)
  assignedToUserId  String?                  @map("assigned_to_user_id") @db.Uuid
  slaDueAt          DateTime?                @map("sla_due_at") @db.Timestamptz(6)
  slaBreachedAt     DateTime?                @map("sla_breached_at") @db.Timestamptz(6)
  rating            Int?
  feedback          String?                  @db.Text
  resolvedAt        DateTime?                @map("resolved_at") @db.Timestamptz(6)
  createdAt         DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  citizen           Citizen                  @relation(fields: [citizenId], references: [id], onDelete: Restrict)
  tenant            Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedToUser    User?                    @relation("GrievanceAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  timeline          GrievanceTimelineEntry[]
  attachments       GrievanceAttachment[]

  @@unique([tenantId, grievanceNo])
  @@index([tenantId, citizenId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, slaDueAt])
  @@map("grievances")
}

model GrievanceTimelineEntry {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  grievanceId  String    @map("grievance_id") @db.Uuid
  eventType    String    @map("event_type") @db.VarChar(40)
  actorSubject String    @map("actor_subject") @db.VarChar(255)
  body         String?
  metadata     Json      @default(dbgenerated("'{}'::jsonb"))
  occurredAt   DateTime  @default(now()) @map("occurred_at") @db.Timestamptz(6)
  grievance    Grievance @relation(fields: [grievanceId], references: [id], onDelete: Cascade)
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, grievanceId, occurredAt])
  @@map("grievance_timeline")
}

model GrievanceAttachment {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  grievanceId String    @map("grievance_id") @db.Uuid
  storageKey  String    @map("storage_key") @db.VarChar(500)
  contentType String    @default("application/octet-stream") @map("content_type") @db.VarChar(120)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  grievance   Grievance @relation(fields: [grievanceId], references: [id], onDelete: Cascade)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, grievanceId])
  @@map("grievance_attachments")
}

model HoldingRecord {
  id                String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String               @map("tenant_id") @db.Uuid
  holdingNumber     String               @map("holding_number") @db.VarChar(80)
  ownerDisplayName  String               @map("owner_display_name") @db.VarChar(255)
  wardNumber        String               @map("ward_number") @db.VarChar(20)
  locality          String               @db.VarChar(150)
  address           Json
  propertyType      String               @map("property_type") @db.VarChar(80)
  outstandingAmount Decimal              @default(0) @map("outstanding_amount") @db.Decimal(12, 2)
  source            String               @default("local_mirror") @db.VarChar(80)
  sourceUpdatedAt   DateTime             @map("source_updated_at") @db.Timestamptz(6)
  isActive          Boolean              @default(true) @map("is_active")
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  tenant            Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lookupAudit       HoldingLookupAudit[]

  @@unique([tenantId, holdingNumber])
  @@index([tenantId, ownerDisplayName])
  @@index([tenantId, wardNumber])
  @@map("holding_records")
}

model HoldingLookupAudit {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String         @map("tenant_id") @db.Uuid
  holdingId     String?        @map("holding_id") @db.Uuid
  holdingNumber String         @map("holding_number") @db.VarChar(80)
  actorSubject  String         @map("actor_subject") @db.VarChar(255)
  outcome       String         @db.VarChar(30)
  source        String         @default("local_mirror") @db.VarChar(80)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  holding       HoldingRecord? @relation(fields: [holdingId], references: [id], onDelete: SetNull)
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, holdingNumber, createdAt])
  @@index([tenantId, outcome])
  @@map("holding_lookup_audit")
}

model RentalAsset {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String            @map("tenant_id") @db.Uuid
  assetType          RentalAssetType   @map("asset_type")
  name               Json
  location           Json              @default(dbgenerated("'{}'::jsonb"))
  status             RentalAssetStatus @default(AVAILABLE)
  baseLeaseRatePaise Int               @default(0) @map("base_lease_rate_paise")
  ratePeriod         RatePeriod        @map("rate_period")
  metadata           Json              @default(dbgenerated("'{}'::jsonb"))
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  agreements         LeaseAgreement[]
  tenant             Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@map("rental_assets")
}

model LeaseAgreement {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String                @map("tenant_id") @db.Uuid
  assetId              String                @map("asset_id") @db.Uuid
  tradeLicenseNo       String                @map("trade_license_no") @db.VarChar(100)
  lessorName           String                @map("lessor_name") @db.VarChar(255)
  lessorPhone          String?               @map("lessor_phone") @db.VarChar(20)
  lessorCitizenId      String?               @map("lessor_citizen_id") @db.Uuid
  startDate            DateTime              @map("start_date") @db.Timestamptz(6)
  endDate              DateTime              @map("end_date") @db.Timestamptz(6)
  securityDepositPaise Int                   @default(0) @map("security_deposit_paise")
  status               LeaseAgreementStatus  @default(DRAFT)
  agreementDocumentKey String?               @map("agreement_document_key") @db.Text
  createdAt            DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  asset                RentalAsset           @relation(fields: [assetId], references: [id], onDelete: Restrict)
  lessorCitizen        Citizen?              @relation(fields: [lessorCitizenId], references: [id], onDelete: SetNull)
  invoices             LeaseInvoice[]
  documents LeaseAgreementDocument[]
  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, tradeLicenseNo])
  @@map("lease_agreements")
}

model LeaseInvoice {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String              @map("tenant_id") @db.Uuid
  agreementId   String              @map("agreement_id") @db.Uuid
  invoiceNo     String              @map("invoice_no") @db.VarChar(100)
  periodStart   DateTime            @map("period_start") @db.Timestamptz(6)
  periodEnd     DateTime            @map("period_end") @db.Timestamptz(6)
  dueDate       DateTime            @map("due_date") @db.Timestamptz(6)
  amountPaise   Int                 @map("amount_paise")
  lateFeePaise  Int                 @default(0) @map("late_fee_paise")
  status        LeaseInvoiceStatus  @default(PENDING)
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  agreement     LeaseAgreement      @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  payments      Payment[]
  receipts      Receipt[]
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, invoiceNo])
  @@index([tenantId, status, dueDate])
  @@map("lease_invoices")
}

model LeaseAgreementDocument {
  id            String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String                       @map("tenant_id") @db.Uuid
  agreementId   String                       @map("agreement_id") @db.Uuid
  fileName      String                       @map("file_name") @db.VarChar(255)
  mimeType      String                       @map("mime_type") @db.VarChar(120)
  sizeBytes     Int                          @map("size_bytes")
  sha256        String                       @db.Char(64)
  storageKey    String                       @map("storage_key") @db.Text
  status        LeaseAgreementDocumentStatus @default(PENDING_REVIEW)
  // JWT `sub` for tenant-staff users is the Keycloak username (per the
  // `sub-username` mapper), not a UUID. Store the principal subject as text
  // for human-readable audit trails; the agreement/tenant FKs are still UUIDs.
  uploadedBy    String                       @map("uploaded_by") @db.VarChar(255)
  uploadedAt    DateTime                     @default(now()) @map("uploaded_at") @db.Timestamptz(6)
  reviewedBy    String?                      @map("reviewed_by") @db.VarChar(255)
  reviewedAt    DateTime?                    @map("reviewed_at") @db.Timestamptz(6)
  reviewerNote  String?                      @map("reviewer_note") @db.Text
  events        LeaseAgreementDocumentEvent[]
  agreement     LeaseAgreement               @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  tenant        Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, uploadedAt])
  @@map("lease_agreement_documents")
}

model LeaseAgreementDocumentEvent {
  id          String                                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String                                   @map("tenant_id") @db.Uuid
  documentId  String                                   @map("document_id") @db.Uuid
  eventType   LeaseAgreementDocumentEventType  @map("event_type")
  // Same as LeaseAgreementDocument.uploadedBy: tenant-staff principals are
  // identified by username in this codebase, not by user UUID.
  actorUserId String                                   @map("actor_user_id") @db.VarChar(255)
  payload     Json                                     @default(dbgenerated("'{}'::jsonb"))
  createdAt   DateTime                                 @default(now()) @map("created_at") @db.Timestamptz(6)
  document    LeaseAgreementDocument                   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tenant      Tenant                                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, documentId, createdAt])
  @@map("lease_agreement_document_events")
}

model SmartZone {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String       @map("tenant_id") @db.Uuid
  code         String       @db.VarChar(80)
  name         Json
  wardId       String?      @map("ward_id") @db.Uuid
  geo          Json?        @default(dbgenerated("'{}'::jsonb"))
  metadata     Json         @default(dbgenerated("'{}'::jsonb"))
  capacityBays Int          @map("capacity_bays")
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  parkingBays  ParkingBay[]
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ward         Ward?        @relation(fields: [wardId], references: [id], onDelete: SetNull)

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("smart_zones")
}

model ParkingBay {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String           @map("tenant_id") @db.Uuid
  zoneId       String           @map("zone_id") @db.Uuid
  bayCode      String           @map("bay_code") @db.VarChar(40)
  status       ParkingBayStatus @default(FREE)
  lastSensorAt DateTime?        @map("last_sensor_at") @db.Timestamptz(6)
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  zone         SmartZone        @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, zoneId, bayCode])
  @@index([tenantId, zoneId, status])
  @@map("parking_bays")
}

enum EvSessionStatus {
  HELD
  CHARGING
  COMPLETED
  CANCELLED
}

enum WaterMeterRechargeStatus {
  PENDING
  CREDITED
  CANCELLED
}

model EvCharger {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String      @map("tenant_id") @db.Uuid
  code             String      @db.VarChar(80)
  name             Json
  location         Json        @default(dbgenerated("'{}'::jsonb"))
  connectorType    String      @map("connector_type") @db.VarChar(20)
  maxKw            Decimal     @map("max_kw") @db.Decimal(6, 2)
  ratePaisePerKwh  Int         @map("rate_paise_per_kwh")
  isActive         Boolean     @default(true) @map("is_active")
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant           Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions         EvSession[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("ev_chargers")
}

model EvSession {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String          @map("tenant_id") @db.Uuid
  chargerId      String          @map("charger_id") @db.Uuid
  citizenId      String          @map("citizen_id") @db.Uuid
  vehicleNumber  String?         @map("vehicle_number") @db.VarChar(20)
  status         EvSessionStatus @default(HELD)
  holdExpiresAt  DateTime?       @map("hold_expires_at") @db.Timestamptz(6)
  startedAt      DateTime?       @map("started_at") @db.Timestamptz(6)
  endedAt        DateTime?       @map("ended_at") @db.Timestamptz(6)
  kwhConsumed    Decimal?        @map("kwh_consumed") @db.Decimal(10, 3)
  amountPaise    Int?            @map("amount_paise")
  paymentId      String?         @map("payment_id") @db.Uuid
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  charger        EvCharger       @relation(fields: [chargerId], references: [id], onDelete: Cascade)
  citizen        Citizen         @relation(fields: [citizenId], references: [id], onDelete: Cascade)
  payments       Payment[]
  receipts       Receipt[]

  @@index([tenantId, chargerId, status])
  @@index([tenantId, citizenId, status])
  @@index([tenantId, status, holdExpiresAt])
  @@map("ev_sessions")
}

model WaterMeterAccount {
  id                String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String                 @map("tenant_id") @db.Uuid
  citizenId         String?                @map("citizen_id") @db.Uuid
  meterId           String                 @map("meter_id") @db.VarChar(80)
  consumerName      String                 @map("consumer_name") @db.VarChar(160)
  consumerPhone     String?                @map("consumer_phone") @db.VarChar(15)
  balancePaise      Int                    @default(0) @map("balance_paise")
  lastReadingLitres Int?                   @map("last_reading_litres")
  lastReadingAt     DateTime?              @map("last_reading_at") @db.Timestamptz(6)
  isActive          Boolean                @default(true) @map("is_active")
  createdAt         DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant            Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  citizen           Citizen?               @relation(fields: [citizenId], references: [id], onDelete: SetNull)
  recharges         WaterMeterRecharge[]

  @@unique([tenantId, meterId])
  @@index([tenantId, consumerPhone])
  @@index([tenantId, isActive])
  @@map("water_meter_accounts")
}

model WaterMeterRecharge {
  id                String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String                   @map("tenant_id") @db.Uuid
  accountId         String                   @map("account_id") @db.Uuid
  citizenSubject    String                   @map("citizen_subject") @db.VarChar(255)
  amountPaise       Int                      @map("amount_paise")
  status            WaterMeterRechargeStatus @default(PENDING)
  paymentId         String?                  @unique @map("payment_id") @db.Uuid
  balanceAfterPaise Int?                     @map("balance_after_paise")
  createdAt         DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  creditedAt        DateTime?                @map("credited_at") @db.Timestamptz(6)
  tenant            Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account           WaterMeterAccount        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  payment           Payment?                 @relation("WaterMeterRechargeSettledPayment", fields: [paymentId], references: [id], onDelete: SetNull)
  targetPayments    Payment[]                @relation("WaterMeterRechargePaymentTarget")
  receipts          Receipt[]

  @@index([tenantId, accountId, createdAt(sort: Desc)])
  @@index([tenantId, status, createdAt])
  @@map("water_meter_recharges")
}
