generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code             String         @unique @db.VarChar(20)
  name             String         @db.VarChar(255)
  district         String?        @db.VarChar(100)
  wardCount        Int?           @map("ward_count")
  themeColor       String?        @map("theme_color") @db.VarChar(7)
  logoUrl          String?        @map("logo_url")
  languagesEnabled String[]       @default(["en", "bn", "hi"]) @map("languages_enabled")
  config           Json           @default(dbgenerated("'{}'::jsonb"))
  isActive         Boolean        @default(true) @map("is_active")
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenantConfig     TenantConfig?
  boroughs         Borough[]
  citizens         Citizen[]
  localities       Locality[]
  notifications    Notification[]
  applicationComments ApplicationComment[]
  applicationDocuments ApplicationDocument[]
  applicationTimeline ApplicationTimeline[]
  applications     Application[]
  paymentIdempotencyKeys PaymentIdempotencyKey[]
  payments         Payment[]
  holdingLookupAudit HoldingLookupAudit[]
  holdingRecords   HoldingRecord[]
  roleStageMaps    RoleStageMap[]
  serviceFormVersions ServiceFormVersion[]
  services         TenantService[]
  userRoles        UserRole[]
  users            User[]
  wards            Ward[]
  workflowStages   WorkflowStage[]
  workflowTransitions WorkflowTransition[]
  workflows        Workflow[]

  @@map("tenants")
}

model TenantConfig {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @unique @map("tenant_id") @db.Uuid
  defaultLanguage String   @default("en") @map("default_language") @db.VarChar(5)
  timezone        String   @default("Asia/Kolkata") @db.VarChar(64)
  contactPhone    String?  @map("contact_phone") @db.VarChar(20)
  contactEmail    String?  @map("contact_email") @db.VarChar(255)
  branding        Json     @default(dbgenerated("'{}'::jsonb"))
  featureFlags    Json     @default(dbgenerated("'{}'::jsonb")) @map("feature_flags")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_config")
}

model Citizen {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String         @map("tenant_id") @db.Uuid
  keycloakSubject String?      @map("keycloak_subject") @db.VarChar(255)
  mobile        String         @db.VarChar(15)
  aadhaarHash   String?        @map("aadhaar_hash") @db.Char(64)
  name          String?        @db.VarChar(255)
  address       Json?          @default(dbgenerated("'{}'::jsonb"))
  wardId        String?        @map("ward_id") @db.Uuid
  holdingNumber String?        @map("holding_number") @db.VarChar(50)
  languagePref  String         @default("en") @map("language_pref") @db.VarChar(5)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ward          Ward?          @relation(fields: [wardId], references: [id], onDelete: SetNull)
  notifications Notification[]
  applications   Application[]

  @@unique([tenantId, mobile])
  @@unique([tenantId, keycloakSubject])
  @@index([tenantId, keycloakSubject])
  @@index([tenantId, wardId])
  @@map("citizens")
}

model User {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String     @map("tenant_id") @db.Uuid
  keycloakUserId String     @unique @map("keycloak_user_id") @db.Uuid
  username       String     @db.VarChar(100)
  email          String?    @db.VarChar(255)
  mobile         String?    @db.VarChar(15)
  displayName    String     @map("display_name") @db.VarChar(255)
  status         String     @default("active") @db.VarChar(20)
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles      UserRole[]

  @@unique([tenantId, username])
  @@index([tenantId, status])
  @@map("users")
}

model Role {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String     @unique @db.VarChar(50)
  name        String     @db.VarChar(100)
  description String?
  isSystem    Boolean    @default(true) @map("is_system")
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  userRoles   UserRole[]

  @@map("roles")
}

model UserRole {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  wardId    String?  @map("ward_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ward      Ward?    @relation(fields: [wardId], references: [id], onDelete: SetNull)

  @@unique([tenantId, userId, roleId, wardId])
  @@index([tenantId, roleId])
  @@map("user_roles")
}

model Borough {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  code      String   @db.VarChar(20)
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  wards     Ward[]

  @@unique([tenantId, code])
  @@map("boroughs")
}

model Ward {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String     @map("tenant_id") @db.Uuid
  boroughId     String?    @map("borough_id") @db.Uuid
  number        String     @db.VarChar(20)
  name          String?    @db.VarChar(100)
  councillor    String?    @db.VarChar(255)
  boundary      Json?      @default(dbgenerated("'{}'::jsonb"))
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  borough       Borough?   @relation(fields: [boroughId], references: [id], onDelete: SetNull)
  citizens      Citizen[]
  localities    Locality[]
  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles     UserRole[]

  @@unique([tenantId, number])
  @@index([tenantId, boroughId])
  @@map("wards")
}

model Locality {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  wardId    String?  @map("ward_id") @db.Uuid
  name      String   @db.VarChar(150)
  pincode   String?  @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ward      Ward?    @relation(fields: [wardId], references: [id], onDelete: SetNull)

  @@unique([tenantId, name, pincode])
  @@index([tenantId, wardId])
  @@map("localities")
}

model Notification {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  citizenId String?   @map("citizen_id") @db.Uuid
  type      String    @db.VarChar(30)
  title     String    @db.VarChar(255)
  body      String
  deepLink  String?   @map("deep_link")
  isRead    Boolean   @default(false) @map("is_read")
  sentAt    DateTime  @default(now()) @map("sent_at") @db.Timestamptz(6)
  readAt    DateTime? @map("read_at") @db.Timestamptz(6)
  citizen   Citizen?  @relation(fields: [citizenId], references: [id], onDelete: SetNull)
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, citizenId, isRead])
  @@map("notifications")
}

model RevenueHead {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String          @unique @db.VarChar(50)
  name           Json
  accountingCode String          @map("accounting_code") @db.VarChar(50)
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  globalServices GlobalService[]
  tenantServices TenantService[]

  @@map("revenue_heads")
}

model ServiceCategory {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String          @unique @db.VarChar(50)
  name           Json
  description    Json?           @default(dbgenerated("'{}'::jsonb"))
  sortOrder      Int             @default(0) @map("sort_order")
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  globalServices GlobalService[]
  tenantServices TenantService[]

  @@index([sortOrder])
  @@map("service_categories")
}

model GlobalService {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                String            @unique @db.VarChar(80)
  categoryId          String            @map("category_id") @db.Uuid
  revenueHeadId       String?           @map("revenue_head_id") @db.Uuid
  name                Json
  description         Json              @default(dbgenerated("'{}'::jsonb"))
  workflowPattern     String            @map("workflow_pattern") @db.VarChar(50)
  defaultSlaDays      Int?              @map("default_sla_days")
  feeType             String            @default("fixed") @map("fee_type") @db.VarChar(30)
  feeConfig           Json              @default(dbgenerated("'{}'::jsonb")) @map("fee_config")
  requiredDocuments   Json              @default(dbgenerated("'[]'::jsonb")) @map("required_documents")
  formSchema          Json              @default(dbgenerated("'{}'::jsonb")) @map("form_schema")
  workflowConfig      Json              @default(dbgenerated("'{}'::jsonb")) @map("workflow_config")
  pushesToDigilocker  Boolean           @default(false) @map("pushes_to_digilocker")
  isActive            Boolean           @default(true) @map("is_active")
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  category            ServiceCategory   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  documents           ServiceDocument[]
  revenueHead         RevenueHead?      @relation(fields: [revenueHeadId], references: [id], onDelete: SetNull)
  tenantServices      TenantService[]

  @@index([categoryId, isActive])
  @@index([revenueHeadId])
  @@map("global_services")
}

model TenantService {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String               @map("tenant_id") @db.Uuid
  globalServiceId    String?              @map("global_service_id") @db.Uuid
  code               String               @db.VarChar(80)
  categoryId         String               @map("category_id") @db.Uuid
  revenueHeadId      String?              @map("revenue_head_id") @db.Uuid
  name               Json
  description        Json                 @default(dbgenerated("'{}'::jsonb"))
  isActive           Boolean              @default(true) @map("is_active")
  overrideConfig     Json                 @default(dbgenerated("'{}'::jsonb")) @map("override_config")
  effectiveFeeConfig Json                 @default(dbgenerated("'{}'::jsonb")) @map("effective_fee_config")
  effectiveSlaDays   Int?                 @map("effective_sla_days")
  requiredDocuments  Json                 @default(dbgenerated("'[]'::jsonb")) @map("required_documents")
  formSchemaAdditions Json                @default(dbgenerated("'{}'::jsonb")) @map("form_schema_additions")
  workflowOverrides  Json                 @default(dbgenerated("'{}'::jsonb")) @map("workflow_overrides")
  version            Int                  @default(1)
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  category           ServiceCategory      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  formVersions       ServiceFormVersion[]
  globalService      GlobalService?       @relation(fields: [globalServiceId], references: [id], onDelete: SetNull)
  applications       Application[]
  revenueHead        RevenueHead?         @relation(fields: [revenueHeadId], references: [id], onDelete: SetNull)
  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflows          Workflow[]

  @@unique([tenantId, code])
  @@index([tenantId, categoryId, isActive])
  @@index([tenantId, globalServiceId])
  @@map("services")
}

model ServiceDocument {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  globalServiceId String        @map("global_service_id") @db.Uuid
  code            String        @db.VarChar(80)
  label           Json
  accept          String[]      @default(["application/pdf", "image/jpeg"])
  maxSizeMb       Int           @default(10) @map("max_size_mb")
  isStatutory     Boolean       @default(false) @map("is_statutory")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  globalService   GlobalService @relation(fields: [globalServiceId], references: [id], onDelete: Cascade)

  @@unique([globalServiceId, code])
  @@map("service_documents")
}

model ServiceFormVersion {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String        @map("tenant_id") @db.Uuid
  serviceId     String        @map("service_id") @db.Uuid
  version       Int
  formSchema    Json          @map("form_schema")
  uiSchema      Json          @default(dbgenerated("'{}'::jsonb")) @map("ui_schema")
  status        String        @default("draft") @db.VarChar(20)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  publishedAt   DateTime?     @map("published_at") @db.Timestamptz(6)
  service       TenantService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  applications  Application[]

  @@unique([tenantId, serviceId, version])
  @@index([tenantId, serviceId, status])
  @@map("service_form_versions")
}

model Workflow {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String               @map("tenant_id") @db.Uuid
  serviceId   String               @map("service_id") @db.Uuid
  code        String               @db.VarChar(80)
  version     Int                  @default(1)
  name        Json
  status      String               @default("draft") @db.VarChar(20)
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  publishedAt DateTime?            @map("published_at") @db.Timestamptz(6)
  applications Application[]
  service     TenantService        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  stages      WorkflowStage[]
  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transitions WorkflowTransition[]

  @@unique([tenantId, serviceId, version])
  @@index([tenantId, status])
  @@map("workflows")
}

model WorkflowStage {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String               @map("tenant_id") @db.Uuid
  workflowId    String               @map("workflow_id") @db.Uuid
  code          String               @db.VarChar(80)
  label         Json
  ownerRole     String               @map("owner_role") @db.VarChar(80)
  slaHours      Int?                 @map("sla_hours")
  isInitial     Boolean              @default(false) @map("is_initial")
  isTerminal    Boolean              @default(false) @map("is_terminal")
  sortOrder     Int                  @default(0) @map("sort_order")
  applications  Application[]
  roleStageMaps RoleStageMap[]
  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflow      Workflow             @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  fromTransitions WorkflowTransition[] @relation("WorkflowTransitionFrom")
  toTransitions WorkflowTransition[] @relation("WorkflowTransitionTo")

  @@unique([tenantId, workflowId, code])
  @@index([tenantId, workflowId, sortOrder])
  @@map("workflow_stages")
}

model WorkflowTransition {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid
  workflowId      String        @map("workflow_id") @db.Uuid
  fromStageId     String        @map("from_stage_id") @db.Uuid
  toStageId       String        @map("to_stage_id") @db.Uuid
  verb            String        @db.VarChar(80)
  actorRole       String        @map("actor_role") @db.VarChar(80)
  requiresComment Boolean       @default(false) @map("requires_comment")
  sideEffects     Json          @default(dbgenerated("'[]'::jsonb")) @map("side_effects")
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflow        Workflow      @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  fromStage       WorkflowStage @relation("WorkflowTransitionFrom", fields: [fromStageId], references: [id], onDelete: Cascade)
  toStage         WorkflowStage @relation("WorkflowTransitionTo", fields: [toStageId], references: [id], onDelete: Cascade)

  @@unique([tenantId, workflowId, fromStageId, verb])
  @@index([tenantId, workflowId, actorRole])
  @@map("workflow_transitions")
}

model RoleStageMap {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String        @map("tenant_id") @db.Uuid
  stageId    String        @map("stage_id") @db.Uuid
  roleCode   String        @map("role_code") @db.VarChar(80)
  canView    Boolean       @default(true) @map("can_view")
  canAct     Boolean       @default(false) @map("can_act")
  stage      WorkflowStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, stageId, roleCode])
  @@index([tenantId, roleCode])
  @@map("role_stage_map")
}

model Application {
  id              String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String                @map("tenant_id") @db.Uuid
  citizenId       String                @map("citizen_id") @db.Uuid
  serviceId       String                @map("service_id") @db.Uuid
  formVersionId   String?               @map("form_version_id") @db.Uuid
  workflowId      String?               @map("workflow_id") @db.Uuid
  currentStageId  String?               @map("current_stage_id") @db.Uuid
  docketNo        String                @unique @map("docket_no") @db.VarChar(80)
  serviceCode     String                @map("service_code") @db.VarChar(80)
  formVersion     Int                   @map("form_version")
  workflowVersion Int                   @default(1) @map("workflow_version")
  status          String                @default("submitted") @db.VarChar(40)
  statusLabel     Json                  @default(dbgenerated("'{}'::jsonb")) @map("status_label")
  pendingRole     String?               @map("pending_role") @db.VarChar(80)
  formData        Json                  @map("form_data")
  runtimeSnapshot Json                  @default(dbgenerated("'{}'::jsonb")) @map("runtime_snapshot")
  paymentStatus   String                @default("not_required") @map("payment_status") @db.VarChar(30)
  submittedAt     DateTime              @default(now()) @map("submitted_at") @db.Timestamptz(6)
  updatedAt       DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  citizen         Citizen               @relation(fields: [citizenId], references: [id], onDelete: Cascade)
  comments        ApplicationComment[]
  currentStage    WorkflowStage?        @relation(fields: [currentStageId], references: [id], onDelete: SetNull)
  documents       ApplicationDocument[]
  formVersionRef  ServiceFormVersion?   @relation(fields: [formVersionId], references: [id], onDelete: SetNull)
  payments        Payment[]
  service         TenantService         @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  timeline        ApplicationTimeline[]
  workflow        Workflow?             @relation(fields: [workflowId], references: [id], onDelete: SetNull)

  @@index([tenantId, citizenId, submittedAt])
  @@index([tenantId, serviceId, status])
  @@map("applications")
}

model ApplicationTimeline {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String      @map("tenant_id") @db.Uuid
  applicationId String      @map("application_id") @db.Uuid
  fromStage     String?     @map("from_stage") @db.VarChar(80)
  toStage       String      @map("to_stage") @db.VarChar(80)
  verb          String      @db.VarChar(80)
  actorSubject  String?     @map("actor_subject") @db.VarChar(255)
  actorRole     String?     @map("actor_role") @db.VarChar(80)
  comment       String?
  metadata      Json        @default(dbgenerated("'{}'::jsonb"))
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, applicationId, createdAt])
  @@map("application_timeline")
}

model ApplicationComment {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String      @map("tenant_id") @db.Uuid
  applicationId String      @map("application_id") @db.Uuid
  actorSubject  String      @map("actor_subject") @db.VarChar(255)
  actorRole     String      @map("actor_role") @db.VarChar(80)
  body          String
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, applicationId, createdAt])
  @@map("application_comments")
}

model ApplicationDocument {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String      @map("tenant_id") @db.Uuid
  applicationId   String      @map("application_id") @db.Uuid
  documentCode    String      @map("document_code") @db.VarChar(80)
  originalName    String      @map("original_name") @db.VarChar(255)
  mimeType        String      @map("mime_type") @db.VarChar(120)
  sizeMb          Decimal     @map("size_mb") @db.Decimal(6, 2)
  objectKey       String      @unique @map("object_key")
  uploadStatus    String      @default("intent_created") @map("upload_status") @db.VarChar(30)
  scanStatus      String      @default("pending") @map("scan_status") @db.VarChar(30)
  scanProvider    String?     @map("scan_provider") @db.VarChar(80)
  scanSignature   String?     @map("scan_signature") @db.VarChar(160)
  scanCompletedAt DateTime?   @map("scan_completed_at") @db.Timestamptz(6)
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  application     Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, applicationId, documentCode])
  @@index([tenantId, scanStatus])
  @@map("application_documents")
}

model Payment {
  id                 String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String                  @map("tenant_id") @db.Uuid
  applicationId      String                  @map("application_id") @db.Uuid
  citizenSubject     String                  @map("citizen_subject") @db.VarChar(255)
  amountPaise        Int                     @map("amount_paise")
  currency           String                  @default("INR") @db.Char(3)
  method             String                  @db.VarChar(30)
  status             String                  @default("requires_action") @db.VarChar(30)
  gateway            String                  @db.VarChar(80)
  gatewayOrderId     String                  @map("gateway_order_id") @db.VarChar(160)
  gatewayPaymentId   String?                 @map("gateway_payment_id") @db.VarChar(160)
  failureCode        String?                 @map("failure_code") @db.VarChar(80)
  failureMessage     String?                 @map("failure_message") @db.VarChar(500)
  createdAt          DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  application        Application             @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  idempotencyRecords PaymentIdempotencyKey[]
  tenant             Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, gateway, gatewayOrderId])
  @@index([tenantId, citizenSubject, createdAt])
  @@index([tenantId, applicationId, status])
  @@map("payments")
}

model PaymentIdempotencyKey {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  citizenSubject     String   @map("citizen_subject") @db.VarChar(255)
  idempotencyKey     String   @map("idempotency_key") @db.VarChar(160)
  requestFingerprint String   @map("request_fingerprint") @db.Char(64)
  paymentId          String   @map("payment_id") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt          DateTime @map("expires_at") @db.Timestamptz(6)
  payment            Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, citizenSubject, idempotencyKey])
  @@index([tenantId, paymentId])
  @@map("payment_idempotency_keys")
}

model HoldingRecord {
  id                String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String               @map("tenant_id") @db.Uuid
  holdingNumber     String               @map("holding_number") @db.VarChar(80)
  ownerDisplayName  String               @map("owner_display_name") @db.VarChar(255)
  wardNumber        String               @map("ward_number") @db.VarChar(20)
  locality          String               @db.VarChar(150)
  address           Json
  propertyType      String               @map("property_type") @db.VarChar(80)
  outstandingAmount Decimal              @default(0) @map("outstanding_amount") @db.Decimal(12, 2)
  source            String               @default("local_mirror") @db.VarChar(80)
  sourceUpdatedAt   DateTime             @map("source_updated_at") @db.Timestamptz(6)
  isActive          Boolean              @default(true) @map("is_active")
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  tenant            Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lookupAudit       HoldingLookupAudit[]

  @@unique([tenantId, holdingNumber])
  @@index([tenantId, ownerDisplayName])
  @@index([tenantId, wardNumber])
  @@map("holding_records")
}

model HoldingLookupAudit {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String         @map("tenant_id") @db.Uuid
  holdingId     String?        @map("holding_id") @db.Uuid
  holdingNumber String         @map("holding_number") @db.VarChar(80)
  actorSubject  String         @map("actor_subject") @db.VarChar(255)
  outcome       String         @db.VarChar(30)
  source        String         @default("local_mirror") @db.VarChar(80)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  holding       HoldingRecord? @relation(fields: [holdingId], references: [id], onDelete: SetNull)
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, holdingNumber, createdAt])
  @@index([tenantId, outcome])
  @@map("holding_lookup_audit")
}
